# Environment Configuration for Absensi Siswa

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=absensi_siswa
DB_USER=root
DB_PASS=

# For Docker/Podman, use service name:
# DB_HOST=db
# DB_PASS=rootpass

# Application Configuration
BASE_URL=/
APP_ENV=development
TIMEZONE=Asia/Jakarta

# Security
APP_SECRET=change_this_to_random_string_min_32_chars

# Upload Configuration
UPLOAD_MAX_SIZE=2M
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf
